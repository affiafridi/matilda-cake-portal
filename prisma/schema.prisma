generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Internal staff / operator accounts.
/// `passwordHash` is optional for now — auth is being added later.
model User {
  id             String               @id @default(cuid())
  name           String
  email          String               @unique
  phone          String?
  passwordHash   String?
  role           UserRole
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  ordersAssigned        Order[]              @relation("OrderAssignedOperator")
  ordersCreated         Order[]              @relation("OrderCreatedBy")
  statusChanges         OrderStatusHistory[] @relation("StatusChangedBy")
  amountChanges         OrderAmountChange[]  @relation("OrderAmountChangedBy")
  sessions              Session[]
  assignedConversations Conversation[]       @relation("InboxAssignedTo")
  sentMessages          Message[]            @relation("MessageSentBy")
  internalNotes         InternalNote[]       @relation("NoteAuthor")

  @@index([role])
  @@index([isActive])
}

/// Server-side session tokens. The cookie holds the plaintext token; the
/// DB stores only its sha256 hash — so a leaked DB row can't impersonate.
/// Cascade-deletes when the User is removed.
model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  @@index([userId])
  @@index([expiresAt])
}

/// Persistent customer profile. An Order may reference one, but the Order
/// also stores a snapshot of customer fields so historical data is preserved
/// even when the profile changes.
model Customer {
  id             String   @id @default(cuid())
  name           String
  phone          String   @unique
  whatsappNumber String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
  conversations  Conversation[]
}

/// A single cake order. Snapshots customer/contact details at creation time
/// so the historical record is stable regardless of later profile edits.
model Order {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  trackingCode    String               @unique
  customerId      String?
  customerName    String
  customerPhone   String
  whatsappNumber  String?
  customerEmail   String?
  deliveryDate    DateTime
  deliveryTime    String
  deliveryAddress String
  deliveryMapLink String?
  orderItems      String
  cakeFlavor      CakeFlavor
  cakeMessage     String?
  cakeSponge      String?
  cakeSize        CakeSize
  /// Required at the application layer when `cakeSize = CUSTOM`.
  customCakeSize  String?
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus        @default(UNPAID)
  totalAmount     Decimal?             @db.Decimal(10, 2)
  advanceAmount   Decimal?             @db.Decimal(10, 2)
  balanceAmount   Decimal?             @db.Decimal(10, 2)
  orderStatus     OrderStatus          @default(RECEIVED)
  source          OrderSource
  notes           String?
  /// Optional link to the operating branch the order is assigned to.
  branchId        String?
  /// Snapshot of the resolved branch label (e.g. "Dubai - Al Qouz") at order time.
  branchName      String?
  createdById     String?
  assignedOperatorId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  assignedOperator User?               @relation("OrderAssignedOperator", fields: [assignedOperatorId], references: [id])
  createdBy       User?                @relation("OrderCreatedBy", fields: [createdById], references: [id])
  customer        Customer?            @relation(fields: [customerId], references: [id])
  branch          Branch?              @relation(fields: [branchId], references: [id])
  statusHistory   OrderStatusHistory[]
  items           OrderItem[]
  amountChanges   OrderAmountChange[]

  @@index([customerPhone])
  @@index([orderStatus])
  @@index([deliveryDate])
  @@index([createdById])
  @@index([assignedOperatorId])
  @@index([customerId])
  @@index([branchId])
}

/// Append-only audit trail for order status transitions.
model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  oldStatus   OrderStatus?
  newStatus   OrderStatus
  changedById String?
  note        String?
  createdAt   DateTime     @default(now())
  changedBy   User?        @relation("StatusChangedBy", fields: [changedById], references: [id])
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedById])
  @@index([createdAt])
}

/// Structured line items per order. Coexists with the existing
/// `Order.orderItems` free-text field — that column is preserved unchanged.
model OrderItem {
  id                     String   @id @default(cuid())
  orderId                String
  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemName               String
  quantity               Int      @default(1)
  unitPrice              Decimal  @db.Decimal(10, 2)
  totalPrice             Decimal  @db.Decimal(10, 2)
  woocommerceProductId   String?
  woocommerceVariationId String?
  variationName          String?
  sizeLabel              String?
  notes                  String?
  /// True when the row is a custom (non-WooCommerce) cake/item.
  isCustom               Boolean  @default(false)
  /// Free-text size description used when sizeLabel is "Custom" (e.g. "2 kg, 3-tier").
  customSize             String?
  /// Persistent reference image URL — file lives in object storage (or /public in dev).
  referenceImageUrl      String?
  referenceImageName     String?
  referenceImageType     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([orderId])
  @@index([woocommerceProductId])
  @@index([woocommerceVariationId])
}

/// Audit row written whenever an order's money fields (total / advance /
/// computed balance) change after creation. Together with the live order
/// row, this gives a full history of who changed the price and why.
model OrderAmountChange {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedById String?
  changedBy   User?    @relation("OrderAmountChangedBy", fields: [changedById], references: [id])
  prevTotal   Decimal? @db.Decimal(10, 2)
  prevAdvance Decimal? @db.Decimal(10, 2)
  prevBalance Decimal? @db.Decimal(10, 2)
  newTotal    Decimal? @db.Decimal(10, 2)
  newAdvance  Decimal? @db.Decimal(10, 2)
  newBalance  Decimal? @db.Decimal(10, 2)
  /// Signed delta on total. Positive = price went up, negative = went down.
  delta       Decimal  @db.Decimal(10, 2)
  reason      String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([changedById])
  @@index([createdAt])
}

/// Operating branch hierarchy — parent (city) and its child (sub-location)
/// branches. An Order is assigned to a child branch in normal use; the
/// resolved label "Parent - Child" is also snapshotted on the Order row.
model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  parent    Branch?  @relation("BranchChildren", fields: [parentId], references: [id])
  children  Branch[] @relation("BranchChildren")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([parentId])
  @@index([isActive])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  OPERATOR
}

enum CakeFlavor {
  VANILLA
  CHOCOLATE
  RED_VELVET
}

enum CakeSize {
  SIZE_750G
  SIZE_1_2KG
  CUSTOM
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderSource {
  WHATSAPP
  WEBSITE
  WALK_IN
  PHONE
}

/// One conversation per WhatsApp contact (keyed by wa_id phone number).
/// Upserted whenever an inbound message arrives.
model Conversation {
  id              String             @id @default(cuid())
  waId            String             @unique
  customerName    String
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  assignedToId    String?
  assignedTo      User?              @relation("InboxAssignedTo", fields: [assignedToId], references: [id])
  status          ConversationStatus @default(OPEN)
  botPaused       Boolean            @default(false)
  lastHumanReplyAt DateTime?
  lastInboundAt   DateTime?
  tags            String[]           @default([])
  unreadCount     Int                @default(0)
  lastMessageAt   DateTime           @default(now())
  lastMessageBody String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  messages        Message[]
  notes           InternalNote[]

  @@index([status])
  @@index([assignedToId])
  @@index([lastMessageAt])
  @@index([customerId])
}

/// Every inbound and outbound WhatsApp message in a conversation.
model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  waMessageId    String?          @unique
  direction      MessageDirection
  messageStatus  String?
  body           String?
  mediaUrl       String?
  mediaType      String?
  sentById       String?
  sentBy         User?            @relation("MessageSentBy", fields: [sentById], references: [id])
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

/// Agent-only notes attached to a conversation — never sent to the customer.
model InternalNote {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?        @relation("NoteAuthor", fields: [authorId], references: [id])
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

/// Saved canned responses. Agents type "/" to search and insert.
model QuickReply {
  id        String   @id @default(cuid())
  shortcut  String   @unique
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

/// A named conversation flow triggered by keywords.
model BotFlow {
  id              Int           @id @default(autoincrement())
  name            String
  description     String?
  triggerKeywords String        @default("") @map("trigger_keywords")
  isActive        Boolean       @default(true) @map("is_active")
  isFallback      Boolean       @default(false) @map("is_fallback")
  sortOrder       Int           @default(0) @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  steps           BotFlowStep[]

  @@map("bot_flows")
}

/// One step in a flow — sends a message with interactive options.
model BotFlowStep {
  id        Int             @id @default(autoincrement())
  flowId    Int             @map("flow_id")
  flow      BotFlow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stepKey   String          @map("step_key")
  message   String
  inputType String          @default("button") @map("input_type")
  isEntry         Boolean         @default(false) @map("is_entry")
  isFallback      Boolean         @default(false) @map("is_fallback")
  showProductCard Boolean         @default(false) @map("show_product_card")
  imageUrl        String?         @map("image_url")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  options   BotFlowOption[]

  @@unique([flowId, stepKey])
  @@map("bot_flow_steps")
}

/// A button or list item within a flow step.
model BotFlowOption {
  id          Int         @id @default(autoincrement())
  stepId      Int         @map("step_id")
  step        BotFlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  label       String
  value       String
  description String?
  nextStepKey String?     @map("next_step_key")
  dataSource     String  @default("static") @map("data_source")
  customApiUrl   String? @map("custom_api_url")
  customApiPath  String? @map("custom_api_path")
  customApiLabel String? @map("custom_api_label")
  customApiValue String? @map("custom_api_value")
  sortOrder      Int     @default(0) @map("sort_order")

  @@map("bot_flow_options")
}

