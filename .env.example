# Copy this file to .env and fill in real values.
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# WooCommerce REST API (server-only — never exposed to the browser).
# WOOCOMMERCE_URL is the WordPress base URL, no trailing slash.
# Generate consumer credentials in WooCommerce → Settings → Advanced → REST API.
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
