# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.
# Never commit .env — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Databases ────────────────────────────────────────────────────────────────

# Portal database (Prisma) — orders, users, sessions, portal_settings
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# WhatsApp bot database — keywords, ai_config, wc_categories, scheduled campaigns
BOT_DATABASE_URL=

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Get these from Meta Business Suite → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── WooCommerce REST API ──────────────────────────────────────────────────────
# WordPress base URL (no trailing slash), e.g. https://shop.yourstore.com
# Generate keys: WooCommerce → Settings → Advanced → REST API
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ── Bot sync ─────────────────────────────────────────────────────────────────
# URL of the Python bot server (used to trigger /reload-config)
BOT_URL=

# Shared secret for bot ↔ portal sync requests
SYNC_SECRET=

# Shared secret for bot → portal inbox webhook (POST /api/inbox/webhook)
# Generate any random string, e.g.: openssl rand -hex 32
INBOX_WEBHOOK_SECRET=

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# GCS bucket name for uploaded images (order references, logos).
# Leave blank in local dev to fall back to public/uploads/ on disk.
# On Cloud Run, uses Application Default Credentials automatically.
GCS_ORDER_IMAGES_BUCKET=

# ── First-run seed (optional) ─────────────────────────────────────────────────
# If set, `npm run db:seed` creates a SUPER_ADMIN user when the User table
# is empty. Safe to leave blank — use the /setup wizard instead.
SEED_SUPER_ADMIN_NAME=
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
